<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/queue_empty_background"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="80dp"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_ticket"
        app:tint="@color/empty_ticket_icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:fontFamily="sans-serif"
        android:text="@string/no_active_queue"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:maxWidth="260dp"
        android:text="@string/no_active_queue_desc"
        android:textColor="@color/empty_subtitle"
        android:textSize="14sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTakeQueueEmpty"
            android:layout_width="200dp"
            android:layout_height="@dimen/queue_button_height"
            android:fontFamily="sans-serif-medium"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/take_queue_now"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"
            app:elevation="0dp" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
