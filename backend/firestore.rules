rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return signedIn() && userDoc().role != null ? userDoc().role : 'customer';
    }

    function isStaff() {
      return signedIn() && userRole() in ['staff', 'manager'];
    }

    function isCustomer() {
      return signedIn() && userRole() == 'customer';
    }

    match /queue_global/{document} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isStaff());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        (request.auth.uid == userId && (!request.resource.data.keys().hasAny(['role'])
            || request.resource.data.role == resource.data.role))
        || isStaff()
      );
      allow delete: if isStaff();

      match /history/{historyId} {
        allow read: if signedIn() && (request.auth.uid == userId || isStaff());
        allow write: if signedIn() && (request.auth.uid == userId || isStaff());
      }
    }

    match /queues/{queueId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && isCustomer();
      allow update: if signedIn() && (
        (resource.data.userId == request.auth.uid && isCustomer())
        || isStaff()
      );
      allow delete: if isStaff();
    }
  }
}
