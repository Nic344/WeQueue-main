<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/queue_detail"
        android:textAppearance="@style/TextAppearance.QueueApp.Headline" />

    <TextView
        android:id="@+id/tvDetailQueueNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAppearance="@style/TextAppearance.QueueApp.Title" />

    <TextView
        android:id="@+id/tvDetailCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textAppearance="@style/TextAppearance.QueueApp.Body" />

    <TextView
        android:id="@+id/tvDetailStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textAppearance="@style/TextAppearance.QueueApp.Body" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCallCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/call_customer" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCompleteQueue"
        style="@style/Widget.QueueApp.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/complete_queue" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSkipQueue"
        style="@style/Widget.QueueApp.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/skip_queue" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelQueueDetail"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/cancel_queue_staff" />
</LinearLayout>
