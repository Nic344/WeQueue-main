<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/staff_surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvStaffProfileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.QueueApp.Headline" />

    <TextView
        android:id="@+id/tvStaffProfileEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.QueueApp.Body" />

    <TextView
        android:id="@+id/tvStaffRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/staff_role_label"
        android:textAppearance="@style/TextAppearance.QueueApp.Body" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStaffLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/staff_primary"
        android:text="@string/staff_logout" />
</LinearLayout>
