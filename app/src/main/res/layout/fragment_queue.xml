<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/queueContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/queueAppBar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/queue_app_bar_height"
                android:background="@color/queue_app_bar_background"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="@string/your_ticket"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/ticketCard"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/queue_ticket_card_height"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_queue_ticket"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginBottom="@dimen/spacing_sm"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_ticket" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_xs"
                            android:fontFamily="sans-serif"
                            android:text="@string/queue_number"
                            android:textColor="@color/ticket_label_white_80"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvTicketNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:fontFamily="sans-serif-black"
                            android:text="A023"
                            android:textColor="@color/white"
                            android:textSize="52sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_md"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="8"
                                android:background="@color/ticket_divider_white_30" />

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:text="@string/position"
                                    android:textColor="@color/ticket_label_white_70"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvPosition"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/spacing_xs"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/white"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:text="@string/estimated_wait"
                                    android:textColor="@color/ticket_label_white_70"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvTicketWait"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/spacing_xs"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/wait_highlight"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefreshQueue"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/queue_button_height"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:fontFamily="sans-serif-medium"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/refresh_queue"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_refresh"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="20dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelQueue"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/queue_button_height"
                    android:layout_marginTop="@dimen/queue_button_gap"
                    android:fontFamily="sans-serif-medium"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/cancel_queue"
                    android:textColor="@color/cancel_red"
                    android:textSize="15sp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/cancel_red"
                    app:strokeWidth="1.5dp" />
            </LinearLayout>
        </LinearLayout>

        <include
            android:id="@+id/emptyQueueState"
            layout="@layout/layout_empty_queue"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible" />

    </FrameLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
